      }
    },
    "Track your consistency, set weekly goals, and watch your cold tolerance grow over time." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Verfolge deine Regelmäßigkeit, setze Wochenziele und beobachte, wie deine Kältetoleranz mit der Zeit wächst." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Registra tu constancia, establece metas semanales y observa cómo crece tu tolerancia al frío." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Suivez votre régularité, fixez des objectifs hebdomadaires et observez votre tolérance au froid progresser." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "継続性を追跡し、週間目標を設定して、冷水耐性の成長を見守りましょう。" } },
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Tutarlılığınızı takip edin, haftalık hedefler belirleyin ve soğuk toleransınızın zamanla artışını izleyin." } }
