        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Bilimsel Bölgeler" } }
      }
    },
    "See real-time benefit zones as you progress through your plunge — from cold shock to deep resilience." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Sieh die Nutzenzonen in Echtzeit während deines Eisbads — vom Kälteschock bis zur tiefen Resilienz." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Observa las zonas de beneficio en tiempo real durante tu inmersión — del shock de frío a la resiliencia profunda." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Visualisez les zones de bénéfices en temps réel pendant votre immersion — du choc thermique à la résilience profonde." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "プランジの進行に合わせてリアルタイムで効果ゾーンを確認 — コールドショックからディープレジリエンスまで。" } },
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Dalışınız boyunca gerçek zamanlı fayda bölgelerini görün — soğuk şokundan derin dayanıklılığa." } }
      }
    },
    "Build Your Streak" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Baue deine Serie auf" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Construye tu racha" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Construisez votre série" } },
