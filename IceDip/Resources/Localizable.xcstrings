    "Track your cold plunge sessions and build resilience through consistent cold exposure." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Verfolge deine Eisbad-Sitzungen und baue Widerstandskraft durch regelmäßige Kälteexposition auf." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Registra tus sesiones de inmersión fría y desarrolla resiliencia con exposición constante al frío." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Suivez vos séances de bain froid et développez votre résilience grâce à une exposition régulière au froid." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "コールドプランジのセッションを記録し、継続的な冷水浴でレジリエンスを高めましょう。" } },
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Soğuk dalış seanslarınızı takip edin ve düzenli soğuk maruziyetiyle dayanıklılık kazanın." } }
